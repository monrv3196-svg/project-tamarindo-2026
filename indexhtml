    --text: #1a1a18;
    --text2: #5a5a56;
    --text3: #9a9890;
    --border: rgba(0,0,0,0.1);
    --border2: rgba(0,0,0,0.18);
    --radius: 12px;
    --purple: #4B3FA0;
    --purple-light: #ede9ff;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1a;
      --bg2: #252523;
      --bg3: #2e2e2b;
      --text: #e8e6de;
      --text2: #a8a69e;
      --text3: #6a6860;
      --border: rgba(255,255,255,0.08);
      --border2: rgba(255,255,255,0.14);
      --purple: #7b6fd4;
      --purple-light: #2a2460;
    }
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
  }
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }
  .header { margin-bottom: 2rem; }
  .header h1 { font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .header p { font-size: 14px; color: var(--text2); }

  /* Tabs */
  .tabs { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .tab {
    padding: 7px 16px; border-radius: 20px; font-size: 13px; cursor: pointer;
    border: 1px solid var(--border2); background: var(--bg2); color: var(--text2);
    transition: all .15s; user-select: none;
  }
  .tab:hover { border-color: var(--purple); color: var(--purple); }
  .tab.active { background: var(--purple); color: var(--purple-light); border-color: var(--purple); }

  /* Legend */
  .legend { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .leg { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text2); }
  .dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

  /* Phase desc */
  .phase-desc {
    font-size: 13px; color: var(--text2); margin-bottom: 14px;
    padding: 10px 14px; background: var(--bg2);
    border-radius: 8px; border-left: 3px solid var(--border2);
  }
  .phase-range { font-weight: 500; color: var(--text); }

  /* Week */
  .week {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius); margin-bottom: 10px; overflow: hidden;
  }
  .week-header {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 16px; cursor: pointer; user-select: none;
  }
  .week-header:hover { background: var(--bg3); }
  .week-num { font-size: 13px; font-weight: 600; min-width: 80px; }
  .week-label { font-size: 13px; color: var(--text2); flex: 1; }
  .week-km { font-size: 12px; color: var(--text3); }
  .week-mini { display: flex; gap: 3px; }
  .mini-day { width: 14px; height: 14px; border-radius: 3px; }
  .chevron { font-size: 11px; color: var(--text3); transition: transform .2s; margin-left: 4px; }
  .chevron.open { transform: rotate(180deg); }

  .week-body { display: none; padding: 0 16px 16px; }
  .week-body.open { display: block; }
  .struct-note {
    font-size: 11px; color: var(--text3); margin-top: 8px; margin-bottom: 2px;
    font-style: italic;
  }

  /* Days grid */
  .days {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px; margin-top: 10px;
  }
  .day-card { border-radius: 8px; padding: 11px 13px; border: 1px solid var(--border); }
  .day-card.run  { background: #E6F1FB; border-color: #B5D4F4; }
  .day-card.gym  { background: #E1F5EE; border-color: #9FE1CB; }
  .day-card.long { background: #FAEEDA; border-color: #FAC775; }
  .day-card.mov  { background: #FBEAF0; border-color: #F4C0D1; }
  .day-card.rest { background: var(--bg3); border-color: var(--border); }
  @media (prefers-color-scheme: dark) {
    .day-card.run  { background: #0C447C28; border-color: #185F8A; }
    .day-card.gym  { background: #08504128; border-color: #0F6E56; }
    .day-card.long { background: #63380628; border-color: #854F0B; }
    .day-card.mov  { background: #72243E28; border-color: #993556; }
  }
  .day-name {
    font-size: 10px; font-weight: 600; text-transform: uppercase;
    letter-spacing: .07em; color: var(--text2); margin-bottom: 3px;
  }
  .day-title { font-size: 13px; font-weight: 600; margin-bottom: 6px; color: var(--text); }
  .day-items { font-size: 12px; color: var(--text2); line-height: 1.8; }
  .day-items li { list-style: none; padding-left: 12px; position: relative; }
  .day-items li::before { content: "–"; position: absolute; left: 0; color: var(--text3); }

  /* Footer */
  .footer { margin-top: 3rem; text-align: center; font-size: 12px; color: var(--text3); }
</style>
</head>
