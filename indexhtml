let activePhase = 0;
const colors = { run:'#3B8BD4', gym:'#1D9E75', long:'#BA7517', mov:'#D4537E', rest:'#888780' };

function showPhase(idx) {
  activePhase = idx;
  document.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', i === idx));
  renderPhase();
}

function renderPhase() {
  const p = PHASES[activePhase];
  let html = `<div class="phase-desc"><span class="phase-range">${p.range}</span> — ${p.desc}</div>`;
  p.weeks.forEach((w, wi) => {
    const id = `w${activePhase}-${wi}`;
    const miniDots = (w.days||[]).map(d => `<div class="mini-day" style="background:${colors[d.type]||colors.rest}"></div>`).join('');
    html += `
      <div class="week">
        <div class="week-header" onclick="toggleWeek('${id}')">
          <span class="week-num">${w.num}</span>
          <span class="week-label">${w.label}</span>
          ${w.km ? `<span class="week-km">${w.km}</span>` : ''}
          <div class="week-mini">${miniDots}</div>
          <span class="chevron" id="chev-${id}">▼</span>
        </div>
        <div class="week-body" id="${id}">
          <div class="struct-note">${STRUCT}</div>
          <div class="days">
            ${(w.days||[]).map(d => `
              <div class="day-card ${d.type}">
                <div class="day-name">${d.name}</div>
                <div class="day-title">${d.title}</div>
                <ul class="day-items">${d.items.map(i=>`<li>${i}</li>`).join('')}</ul>
              </div>`).join('')}
          </div>
        </div>
      </div>`;
  });
  document.getElementById('phase-content').innerHTML = html;
}

function toggleWeek(id) {
  const b = document.getElementById(id);
  const c = document.getElementById('chev-'+id);
  b.classList.toggle('open');
  c.classList.toggle('open', b.classList.contains('open'));
}

renderPhase();
</script>
